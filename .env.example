# Next.js (browser + server components — safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Scripts only (local sync — never expose to Next.js)
# Used by: npm run sync:sipsa-catalog, npm run sync:sipsa-prices -- <code> [--years 3 | --update]
# Also set in Netlify site env for the scheduled sync-sipsa-prices function (3am/3pm Colombia).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SIPSA / DANE API (optional)
# SIPSA_BASE_URL=https://sen.dane.gov.co/variacionPrecioMayoristaSipsa_ws/rest/SipsaServices
# SIPSA_FETCH_TIMEOUT_MS=60000
