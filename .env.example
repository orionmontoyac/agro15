# Next.js (browser + server components — safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Used for absolute og:image / twitter:image URLs when sharing links
# NEXT_PUBLIC_SITE_URL=https://your-agro15-domain.netlify.app

# Scripts only (local sync — never expose to Next.js)
# Used by: npm run sync:sipsa-catalog, npm run sync:sipsa-prices -- <code> [--years 3 | --update]
# Also: sync:sipsa-aggregates, sync:sipsa-supply, sync:sipsa-insumos, sync:sipsa-prices-all-update
# Netlify scheduled: sync-sipsa-prices (2x daily), sync-sipsa-aggregates (daily check),
# sync-sipsa-supply (11th monthly), sync-sipsa-insumos (12th monthly)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SIPSA / DANE API (optional)
# SIPSA_BASE_URL=https://sen.dane.gov.co/variacionPrecioMayoristaSipsa_ws/rest/SipsaServices
# SIPSA_FETCH_TIMEOUT_MS=60000
# SIPSA_SOAP_URL=https://appweb.dane.gov.co/sipsaWS/SrvSipsaUpraBeanService
# DANE_INSUMOS_PAGE_URL=https://www.dane.gov.co/index.php/estadisticas-por-tema/agropecuario/sistema-de-informacion-de-precios-y-abastecimiento-sipsa/sipsa-insumos
# DANE_INSUMOS_HISTORICAL_XLSX_URL=https://www.dane.gov.co/files/operaciones/SIPSA/anex-SIPSAInsumos-SeriesHistoricasMun-2021-2026.xlsx
